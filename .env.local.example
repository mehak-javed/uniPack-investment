# uniPACK environment template — copy to `.env.local` and fill in your keys.
#   cp .env.local.example .env.local
# `.env.local` is git-ignored; this template is committed so contributors know
# which variables are needed. All services have free tiers.

# ── Finnhub (market data) — required for LIVE pricing ──────────────────────────
# Free key: https://finnhub.io  →  Dashboard  →  API key
# Without it, the app serves realistic mock quotes so the UI stays usable.
FINNHUB_API_KEY=

# ── Supabase (auth + cloud-synced portfolios) — optional ───────────────────────
# https://supabase.com  →  Project Settings  →  API
# Without these, portfolio/watchlist persist locally in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
